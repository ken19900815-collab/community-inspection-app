    "standard": "道閘升降正常，無異音、卡頓、遙控失效或安全感應異常。",
    "required": true
  },
  {
    "id": "16-007",
    "seq": 151,
    "locationId": "L16",
    "location": "後哨",
    "category": "設備設施",
    "item": "緊急警報／一鍵求助",
    "standard": "緊急按鈕、警報或求助設備外觀正常，標示清楚，功能無異常。",
    "required": true
  },
  {
    "id": "16-008",
    "seq": 152,
    "locationId": "L16",
    "location": "後哨",
    "category": "環境衛生",
    "item": "哨所清潔",
    "standard": "桌面、地面、窗台、設備表面整潔，無垃圾、食物殘留或異味。",
    "required": true
  },
  {
    "id": "16-009",
    "seq": 153,
    "locationId": "L16",
    "location": "後哨",
    "category": "緊急應變",
    "item": "緊急聯絡表張貼",
    "standard": "最新版緊急聯絡表張貼於明顯位置，內容清楚可讀。",
    "required": true
  },
  {
    "id": "16-010",
    "seq": 154,
    "locationId": "L16",
    "location": "後哨",
    "category": "緊急應變",
    "item": "值班日誌記錄",
    "standard": "值班日誌每班完整填寫，事件、交辦、異常及處理情形不得空白。",
    "required": true
  },
  {
    "id": "16-011",
    "seq": 155,
    "locationId": "L16",
    "location": "後哨",
    "category": "勤務紀律",
    "item": "服裝儀容與崗位狀態",
    "standard": "值勤人員服裝整齊、儀容端正，無睡哨、離崗、滑手機或未依規定執勤情形。",
    "required": true
  }
];
let state = JSON.parse(localStorage.getItem("inspectionState_cloud_v2") || "{}");
let currentLoc = null;
let liffProfile = null;

function initState() {
  if (!state.items) state.items = {};
  for (const item of ITEMS) {
    if (!state.items[item.id]) {
      state.items[item.id] = { result:"", note:"", abnormal:"", action:"", dueDate:"", photos:[] };
    }
  }
  state.meta = state.meta || { startedAt: new Date().toISOString() };
  ["inspector","shift","weather"].forEach(id => {
    const el = document.getElementById(id);
    if (state.meta[id]) el.value = state.meta[id];
    el.addEventListener("input", () => { state.meta[id]=el.value; save(); });
    el.addEventListener("change", () => { state.meta[id]=el.value; save(); });
  });
}

async function initLiff() {
  try {
    await liff.init({ liffId: LIFF_ID });
    if (liff.isLoggedIn()) {
      liffProfile = await liff.getProfile();
      document.getElementById("userInfo").textContent = "登入：" + liffProfile.displayName + "｜LIFF 雲端正式版";
      if (!state.meta.inspector) {
        document.getElementById("inspector").value = liffProfile.displayName;
        state.meta.inspector = liffProfile.displayName; save();
      }
    }
  } catch(e) {
    console.warn("LIFF init failed", e);
  }
}

function save() {
  localStorage.setItem("inspectionState_cloud_v2", JSON.stringify(state));
  updateStats();
}

function updateStats() {
  const total = ITEMS.length;
  let done=0, issue=0;
  for (const item of ITEMS) {
    const r = state.items[item.id]?.result;
    if (r) done++;
    if (r === "異常" || r === "待注意") issue++;
  }
  document.getElementById("sTotal").textContent = total;
  document.getElementById("sDone").textContent = done;
  document.getElementById("sIssue").textContent = issue;
  const pct = Math.round(done/total*100);
  document.getElementById("globalBar").style.width = pct + "%";
  document.getElementById("globalText").textContent = `總進度 ${done}/${total}（${pct}%）`;
  const btn = document.getElementById("submitBtn");
  const validation = validateAll(false);
  btn.disabled = !(done === total && validation.ok);
  btn.textContent = done === total ? (validation.ok ? "總送出巡檢" : "尚有必填未完成") : `尚有 ${total-done} 項`;
  renderLocations();
}

function renderLocations() {
  const box = document.getElementById("locations");
  if (!box) return;
  box.innerHTML = LOCATIONS.map((loc, idx) => {
    const locItems = ITEMS.filter(x=>x.locationId===loc.id);
    const done = locItems.filter(x=>state.items[x.id]?.result).length;
    const issue = locItems.filter(x=>["異常","待注意"].includes(state.items[x.id]?.result)).length;
    const cls = done===locItems.length ? "done" : (issue ? "hasIssue" : "");
    return `<div class="card location ${cls}" onclick="openLocation('${loc.id}')">
      <div class="num">${idx+1}</div>
      <div class="body"><div class="title">${loc.name}</div><div class="muted">完成 ${done}/${locItems.length}｜異常/待注意 ${issue}</div></div>
      <div>›</div>
    </div>`;
  }).join("");
}

function openLocation(id) {
  currentLoc = id;
  const loc = LOCATIONS.find(x=>x.id===id);
  document.getElementById("home").classList.add("hidden");
  document.getElementById("inspection").classList.remove("hidden");
  document.getElementById("locTitle").textContent = loc.name;
  renderItems();
  window.scrollTo(0,0);
}

function backHome() {
  document.getElementById("inspection").classList.add("hidden");
  document.getElementById("home").classList.remove("hidden");
  currentLoc = null;
  updateStats();
}

function renderItems() {
  const list = document.getElementById("itemList");
  const locItems = ITEMS.filter(x=>x.locationId===currentLoc);
  const done = locItems.filter(x=>state.items[x.id]?.result).length;
  document.getElementById("locProgress").textContent = `本區完成 ${done}/${locItems.length}`;
  list.innerHTML = locItems.map(item => renderItem(item)).join("");
}

function esc(s) { return String(s||"").replace(/[&<>"']/g,m=>({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;"}[m])); }

function renderItem(item) {
  const d = state.items[item.id] || {};
  const cls = d.result==="正常"?"normal":d.result==="待注意"?"warnstate":d.result==="異常"?"bad":d.result==="N/A"?"na":"";
  const detail = (d.result==="異常" || d.result==="待注意") ? "" : "hidden";
  return `<div class="card item ${cls}" id="card-${item.id}">
    <span class="badge">${esc(item.category)}</span>
    <h3>${item.seq}. ${esc(item.item)}</h3>
    <div class="standard">${esc(item.standard)}</div>
    <div class="options">
      ${["正常","待注意","異常","N/A"].map(r=>`<button class="${d.result===r?'sel ':''}${r==='正常'?'normal':r==='待注意'?'warnstate':r==='異常'?'bad':'na'}" onclick="setResult('${item.id}','${r}')">${r}</button>`).join("")}
    </div>
    <div id="detail-${item.id}" class="${detail}">
      <label>備註 / 實測值</label>
      <textarea oninput="setField('${item.id}','note',this.value)" placeholder="可填實測值或一般備註">${esc(d.note)}</textarea>
      <label>異常說明</label>
      <textarea oninput="setField('${item.id}','abnormal',this.value)" placeholder="選異常時必填">${esc(d.abnormal)}</textarea>
      <label>處理方式</label>
      <textarea oninput="setField('${item.id}','action',this.value)" placeholder="選異常時必填">${esc(d.action)}</textarea>
      <label>預計完成日</label>
      <input type="date" value="${esc(d.dueDate)}" onchange="setField('${item.id}','dueDate',this.value)" />
    </div>
    <label>照片（可多張）</label>
    <input type="file" accept="image/*" capture="environment" multiple onchange="addPhotos('${item.id}',this.files)" />
    <div class="photoRow" id="photos-${item.id}">${(d.photos||[]).map((p,i)=>`<img class="thumb" src="${p.preview||p.url}" onclick="removePhoto('${item.id}',${i})" title="點擊移除">`).join("")}</div>
  </div>`;
}

function setResult(id, result) {
  state.items[id].result = result;
  if (result === "正常" || result === "N/A") {
    state.items[id].abnormal = state.items[id].abnormal || "";
    state.items[id].action = state.items[id].action || "";
  }
  save();
  renderItems();
}

function setField(id, field, val) {
  state.items[id][field] = val;
  save();
}

async function addPhotos(id, files) {
  const arr = state.items[id].photos || [];
  for (const file of Array.from(files)) {
    const dataUrl = await resizeImage(file, 1280, 0.78);
    arr.push({ name:file.name, preview:dataUrl, uploaded:false });
  }
  state.items[id].photos = arr;
  save();
  renderItems();
}

function removePhoto(id, index) {
  if (!confirm("移除這張照片？")) return;
  state.items[id].photos.splice(index,1);
  save();
  renderItems();
}

function resizeImage(file, maxSize, quality) {
  return new Promise((resolve,reject)=>{
    const img = new Image();
    const reader = new FileReader();
    reader.onload = e => { img.onload = () => {
      let w=img.width, h=img.height;
      if (Math.max(w,h)>maxSize) { const ratio=maxSize/Math.max(w,h); w=Math.round(w*ratio); h=Math.round(h*ratio); }
      const canvas=document.createElement("canvas"); canvas.width=w; canvas.height=h;
      canvas.getContext("2d").drawImage(img,0,0,w,h);
      resolve(canvas.toDataURL("image/jpeg", quality));
    }; img.src=e.target.result; };
    reader.onerror=reject; reader.readAsDataURL(file);
  });
}

function showView(view) {
  document.querySelectorAll(".tabs button").forEach(b=>b.classList.remove("active"));
  event?.target?.classList.add("active");
  document.getElementById("locations").classList.toggle("hidden", view!=="locations");
  document.getElementById("issues").classList.toggle("hidden", view!=="issues");
  if (view==="issues") renderIssues();
}

function renderIssues() {
  const issues = ITEMS.filter(x=>["異常","待注意"].includes(state.items[x.id]?.result));
  document.getElementById("issues").innerHTML = issues.length ? issues.map(item=>{
    const d=state.items[item.id];
    return `<div class="card issueLine">
      <b>${esc(item.location)}｜${esc(item.item)}</b>
      <div class="muted">${esc(item.category)}｜${esc(d.result)}</div>
      <p>${esc(d.abnormal || d.note || "尚未填寫說明")}</p>
      <button class="ghost" onclick="openLocation('${item.locationId}')">前往該區</button>
    </div>`;
  }).join("") : `<div class="card">目前沒有異常或待注意項目。</div>`;
}

function validateAll(showAlert=true) {
  for (const item of ITEMS) {
    const d = state.items[item.id];
    if (!d?.result) return {ok:false, msg:`尚未完成：${item.location} - ${item.item}`};
    if (d.result==="異常" && (!d.abnormal?.trim() || !d.action?.trim())) {
      return {ok:false, msg:`異常必填說明與處理方式：${item.location} - ${item.item}`};
    }
    if (d.result==="待注意" && !d.note?.trim()) {
      return {ok:false, msg:`待注意必填備註：${item.location} - ${item.item}`};
    }
  }
  return {ok:true};
}

async function submitAll() {
  const v = validateAll(true);
  if (!v.ok) { toast(v.msg); return; }
  if (!confirm("確認總送出本次巡檢？送出後主管端即可看到紀錄。")) return;
  const btn = document.getElementById("submitBtn");
  btn.disabled = true; btn.textContent = "上傳中...";
  try {
    for (const item of ITEMS) {
      const photos = state.items[item.id].photos || [];
      for (const p of photos) {
        if (!p.uploaded && p.preview) {
          const up = await fetch("/api/uploadPhoto", {
            method:"POST", headers:{"Content-Type":"application/json"},
            body: JSON.stringify({ dataUrl:p.preview, filename:p.name || `${item.id}.jpg` })
          });
          if (!up.ok) throw new Error(await up.text());
          const r = await up.json();
          p.url = r.url; p.preview = r.url; p.uploaded = true;
        }
      }
    }
    const record = {
      id: "R" + Date.now(),
      submittedAt: new Date().toISOString(),
      meta: {...state.meta, inspector:document.getElementById("inspector").value, shift:document.getElementById("shift").value, weather:document.getElementById("weather").value},
      lineProfile: liffProfile ? { userId:liffProfile.userId, displayName:liffProfile.displayName } : null,
      locations: LOCATIONS,
      items: ITEMS.map(item => ({...item, answer: state.items[item.id]}))
    };
    const res = await fetch("/api/submitInspection", {
      method:"POST", headers:{"Content-Type":"application/json"}, body:JSON.stringify(record)
    });
    if (!res.ok) throw new Error(await res.text());
    localStorage.setItem("lastSubmittedRecord", JSON.stringify(record));
    toast("✅ 巡檢已成功送出雲端");
    btn.textContent = "已送出";
  } catch(e) {
    console.error(e);
    toast("送出失敗：" + e.message);
    btn.disabled = false; btn.textContent = "總送出巡檢";
  }
}

function openAdmin() { window.open("/admin.html", "_blank"); }
function toast(msg) {
  const t=document.getElementById("toast"); t.textContent=msg; t.classList.remove("hidden");
  setTimeout(()=>t.classList.add("hidden"), 3500);
}

window.addEventListener("load", async () => {
  initState();
  await initLiff();
  renderLocations();
  updateStats();
});
</script>
</body>
</html>