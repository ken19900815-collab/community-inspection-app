<!DOCTYPE html>
<html lang="zh-Hant">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
<title>社區巡檢系統</title>
<script src="https://static.line-scdn.net/liff/edge/2/sdk.js"></script>
<style>
:root {
  --bg:#f5f7fb; --card:#fff; --ink:#172033; --muted:#68758a; --line:#e6eaf2;
  --blue:#163b73; --blue2:#2563eb; --green:#12a150; --orange:#f59e0b; --red:#dc2626;
  --shadow:0 8px 24px rgba(15,23,42,.08);
}
* { box-sizing:border-box; }
body { margin:0; background:var(--bg); color:var(--ink); font-family:-apple-system,BlinkMacSystemFont,"Segoe UI","Noto Sans TC",Arial,sans-serif; }
header { position:sticky; top:0; z-index:20; background:linear-gradient(135deg,#102c58,#1f5ca8); color:#fff; padding:16px 16px 14px; box-shadow:0 4px 18px rgba(0,0,0,.18); }
header h1 { margin:0; font-size:20px; letter-spacing:.5px; }
header .sub { margin-top:6px; font-size:13px; opacity:.9; }
main { padding:14px 14px 110px; max-width:980px; margin:auto; }
.card { background:var(--card); border:1px solid var(--line); border-radius:18px; box-shadow:var(--shadow); padding:14px; margin-bottom:12px; }
.grid { display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:10px; }
.stat { border-radius:16px; padding:12px; background:#f8fafc; border:1px solid var(--line); }
.stat b { display:block; font-size:22px; margin-top:5px; }
.muted { color:var(--muted); font-size:13px; }
button { border:0; border-radius:14px; padding:12px 14px; font-weight:800; font-size:15px; cursor:pointer; }
.primary { background:var(--blue2); color:#fff; }
.ghost { background:#eef4ff; color:#194989; }
.danger { background:var(--red); color:#fff; }
.success { background:var(--green); color:#fff; }
.warn { background:#fff7ed; color:#b45309; }
.location { display:flex; align-items:center; gap:12px; padding:14px; }
.location .num { width:36px;height:36px; border-radius:50%; display:grid; place-items:center; background:#e8f0ff; color:#164a91; font-weight:900; }
.location .body { flex:1; }
.location .title { font-weight:900; font-size:17px; }
.location.done { border-color:#bbf7d0; background:#f0fdf4; }
.location.hasIssue { border-color:#fecaca; background:#fff7f7; }
.tabs { display:flex; gap:8px; overflow:auto; padding-bottom:8px; margin-bottom:10px; }
.tabs button { flex:0 0 auto; background:#fff; border:1px solid var(--line); color:#263248; }
.tabs button.active { background:var(--blue); color:#fff; }
.item { border-left:6px solid #cbd5e1; }
.item.normal { border-left-color:var(--green); }
.item.warnstate { border-left-color:var(--orange); background:#fffbeb; }
.item.bad { border-left-color:var(--red); background:#fff7f7; }
.item.na { border-left-color:#64748b; }
.item h3 { margin:0 0 6px; font-size:16px; }
.badge { display:inline-block; padding:4px 9px; border-radius:999px; font-size:12px; font-weight:900; background:#eef2ff; color:#334155; margin-bottom:8px; }
.standard { font-size:14px; color:#475569; line-height:1.5; background:#f8fafc; border-radius:12px; padding:10px; }
.options { display:grid; grid-template-columns:repeat(4,1fr); gap:8px; margin:12px 0; }
.options button { padding:10px 6px; font-size:14px; background:#f1f5f9; color:#334155; border:1px solid #e2e8f0; }
.options button.sel.normal { background:#dcfce7; color:#166534; border-color:#86efac; }
.options button.sel.warnstate { background:#ffedd5; color:#9a3412; border-color:#fdba74; }
.options button.sel.bad { background:#fee2e2; color:#991b1b; border-color:#fca5a5; }
.options button.sel.na { background:#e2e8f0; color:#334155; border-color:#94a3b8; }
textarea,input,select { width:100%; border:1px solid #cbd5e1; border-radius:12px; padding:11px; font-size:16px; background:#fff; }
label { display:block; font-size:13px; font-weight:800; margin:10px 0 5px; color:#334155; }
.hidden { display:none !important; }
.photoRow { display:flex; gap:8px; flex-wrap:wrap; margin-top:8px; }
.thumb { width:72px; height:72px; object-fit:cover; border-radius:12px; border:1px solid #cbd5e1; }
.bottomBar { position:fixed; left:0; right:0; bottom:0; z-index:30; background:rgba(255,255,255,.96); backdrop-filter:blur(10px); border-top:1px solid var(--line); padding:10px 12px calc(10px + env(safe-area-inset-bottom)); box-shadow:0 -6px 20px rgba(15,23,42,.08); }
.bottomInner { max-width:980px; margin:auto; display:flex; align-items:center; gap:10px; }
.progressWrap { flex:1; }
.progress { height:9px; background:#e2e8f0; border-radius:999px; overflow:hidden; margin-top:5px; }
.progress > div { height:100%; background:linear-gradient(90deg,#22c55e,#2563eb); width:0; }
.bigSubmit { min-width:132px; }
.toast { position:fixed; left:16px; right:16px; bottom:90px; z-index:50; padding:13px; border-radius:14px; color:#fff; background:#0f172a; text-align:center; box-shadow:var(--shadow); }
.issueLine { border-left:5px solid var(--red); }
@media (min-width:760px) { .grid { grid-template-columns:repeat(4,1fr); } .options { grid-template-columns:repeat(4,120px); } }
@media (max-width:420px) { .options { grid-template-columns:repeat(2,1fr); } .bottomInner { flex-direction:column; align-items:stretch; } .bigSubmit { width:100%; } }
</style>
</head>
<body>
<header>
  <h1>社區巡檢系統</h1>
  <div class="sub" id="userInfo">LIFF 雲端正式版｜逐點巡檢、總送出、多照片上傳</div>
</header>
<main>
  <section id="home">
    <div class="card">
      <div class="grid">
        <div class="stat"><span class="muted">巡檢點</span><b id="sLoc">16</b></div>
        <div class="stat"><span class="muted">點檢項目</span><b id="sTotal">0</b></div>
        <div class="stat"><span class="muted">已完成</span><b id="sDone">0</b></div>
        <div class="stat"><span class="muted">異常/待注意</span><b id="sIssue">0</b></div>
      </div>
    </div>
    <div class="card">
      <label>巡檢人員</label>
      <input id="inspector" placeholder="請輸入巡檢人員姓名" />
      <label>班別</label>
      <select id="shift"><option>早班</option><option>中班</option><option>晚班</option><option>機動</option></select>
      <label>天氣</label>
      <input id="weather" placeholder="例：晴、陰、雨" />
    </div>
    <div class="tabs">
      <button class="active" onclick="showView('locations')">巡檢點</button>
      <button onclick="showView('issues')">異常追蹤</button>
      <button onclick="openAdmin()">主管後台</button>
    </div>
    <div id="locations"></div>
    <div id="issues" class="hidden"></div>
  </section>
  <section id="inspection" class="hidden">
    <div class="card">
      <button class="ghost" onclick="backHome()">← 回巡檢點</button>
      <h2 id="locTitle" style="margin:12px 0 4px"></h2>
      <div class="muted" id="locProgress"></div>
    </div>
    <div id="itemList"></div>
  </section>
</main>
<div class="bottomBar">
  <div class="bottomInner">
    <div class="progressWrap">
      <div class="muted" id="globalText">尚未開始</div>
      <div class="progress"><div id="globalBar"></div></div>
    </div>
    <button id="submitBtn" class="success bigSubmit" onclick="submitAll()" disabled>總送出巡檢</button>
  </div>
</div>
<div id="toast" class="toast hidden"></div>
