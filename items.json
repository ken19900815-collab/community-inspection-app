let CONFIG={}, profile={userId:'guest',displayName:'未登入'}, locations=[], items=[], records=[], route='home';
let draft={shift:'早班',weather:'',locationId:'',location:'',results:{}};
const $=s=>document.querySelector(s); const app=$('#app');
const api=async (url,opt={})=>{const r=await fetch(url,opt); if(!r.ok) throw new Error(await r.text()); return r.json()};
async function init(){
  CONFIG=await api('/api/config');
  try{ if(CONFIG.liffId){ await liff.init({liffId:CONFIG.liffId}); if(!liff.isLoggedIn()) liff.login(); profile=await liff.getProfile(); }}catch(e){console.warn(e)}
  locations=await api('/api/locations'); items=await api('/api/items'); await loadRecords(); render();
}
async function loadRecords(){records=await api('/api/records')}
function today(){return new Date().toISOString().slice(0,10)}
function setRoute(r){route=r; render(); scrollTo(0,0)}
function header(t,sub=''){return `<div class="top"><div class="title">${t}</div><div class="sub">${sub||profile.displayName||''}</div></div>`}
function nav(){return `<div class="bottom"><button class="tab ${route==='home'?'active':''}" onclick="setRoute('home')">首頁</button><button class="tab ${route==='locations'?'active':''}" onclick="setRoute('locations')">巡檢</button><button class="tab ${route==='abnormal'?'active':''}" onclick="setRoute('abnormal')">異常</button><button class="tab ${route==='admin'?'active':''}" onclick="setRoute('admin')">主管</button></div>`}
function summary(){const ab=records.filter(r=>r.result==='異常'||r.result==='待注意'); const pending=ab.filter(r=>!['已改善','已結案'].includes(r.status)); const doneLoc=new Set(records.filter(r=>(r.date||'').startsWith(today())).map(r=>r.locationId)); return {ab,pending,doneLoc}}
function render(){ if(route==='home') renderHome(); if(route==='locations') renderLocations(); if(route==='inspect') renderInspect(); if(route==='abnormal') renderAbnormal(); if(route==='admin') renderAdmin(); }
function renderHome(){const s=summary(); app.innerHTML=header('社區巡檢管理系統','LINE Bot × LIFF 手機巡檢')+`<div class="wrap"><div class="grid"><div class="stat"><b>${s.doneLoc.size}/${locations.length}</b><span>今日巡檢點</span></div><div class="stat"><b class="dangerText">${s.pending.length}</b><span>待追蹤異常</span></div><div class="stat"><b>${records.filter(r=>(r.date||'').startsWith(today())).length}</b><span>今日項目紀錄</span></div><div class="stat"><b>${s.ab.length}</b><span>累計異常/待注意</span></div></div><div class="card"><h3>快速操作</h3><button class="btn primary" onclick="setRoute('locations')">開始巡檢</button><button class="btn" onclick="setRoute('abnormal')">查看異常追蹤</button><button class="btn dark" onclick="setRoute('admin')">主管儀表板</button></div><div class="card"><h3>使用者</h3><div class="small">${profile.displayName}<br>${profile.userId}</div></div></div>`+nav()}
function renderLocations(){const s=summary(); app.innerHTML=header('選擇巡檢點','一站一站執行，避免漏檢')+`<div class="wrap">${locations.map(l=>{const rs=records.filter(r=>(r.date||'').startsWith(today())&&r.locationId===l.id); const ab=rs.filter(r=>r.result==='異常'||r.result==='待注意').length; return `<div class="card locationCard" onclick="openLocation('${l.id}')"><div><h3>${l.sort}. ${l.name}</h3><span class="pill ${rs.length?'ok':'na'}">${rs.length?'今日已巡':'尚未巡檢'}</span>${ab?`<span class="pill bad">異常 ${ab}</span>`:''}</div><div class="num">›</div></div>`}).join('')}</div>`+nav()}
function openLocation(id){const l=locations.find(x=>x.id===id); draft.locationId=id; draft.location=l.name; draft.results={}; items.filter(x=>x.locationId===id).forEach(x=>draft.results[x.id]={itemId:x.id,category:x.category,item:x.item,standard:x.standard,result:'',note:'',abnormalDescription:'',action:'',dueDate:'',photoUrls:[]}); setRoute('inspect')}
function renderInspect(){const locItems=items.filter(x=>x.locationId===draft.locationId); app.innerHTML=header(draft.location||'巡檢執行','異常會自動展開拍照與處理欄位')+`<div class="wrap"><div class="card"><div class="row"><div><label>班別</label><select onchange="draft.shift=this.value"><option ${draft.shift==='早班'?'selected':''}>早班</option><option ${draft.shift==='中班'?'selected':''}>中班</option><option ${draft.shift==='晚班'?'selected':''}>晚班</option></select></div><div><label>天氣</label><input value="${draft.weather||''}" onchange="draft.weather=this.value" placeholder="晴/雨"></div></div></div>${locItems.map(renderItem).join('')}<button class="btn primary" onclick="submitInspection()">送出本巡檢點</button><button class="btn" onclick="setRoute('locations')">返回巡檢點</button></div>`+nav()}
function renderItem(it){const r=draft.results[it.id]||{}; const cls=r.result==='異常'?'badBorder':r.result==='待注意'?'warnBorder':''; return `<div class="item ${cls}"><h3>${it.seq}. ${it.item}</h3><div class="small"><b>${it.category}</b><br>${it.standard}</div><div class="seg"><button class="${r.result==='正常'?'selected ok':''}" onclick="setResult('${it.id}','正常')">正常</button><button class="${r.result==='待注意'?'selected warn':''}" onclick="setResult('${it.id}','待注意')">待注意</button><button class="${r.result==='異常'?'selected bad':''}" onclick="setResult('${it.id}','異常')">異常</button><button class="${r.result==='不適用'?'selected na':''}" onclick="setResult('${it.id}','不適用')">N/A</button></div>${(r.result==='異常'||r.result==='待注意')?`<label>${r.result==='異常'?'異常說明':'備註'}</label><textarea onchange="draft.results['${it.id}'].abnormalDescription=this.value">${r.abnormalDescription||''}</textarea><label>處理方式</label><textarea onchange="draft.results['${it.id}'].action=this.value">${r.action||''}</textarea><label>預計完成日</label><input type="date" onchange="draft.results['${it.id}'].dueDate=this.value" value="${r.dueDate||''}"><label>拍照上傳</label><input type="file" accept="image/*" capture="environment" onchange="uploadPhoto(event,'${it.id}')"><div>${(r.photoUrls||[]).map(u=>`<img class="photo" src="${u}">`).join('')}</div>`:`<label>備註</label><input onchange="draft.results['${it.id}'].note=this.value" value="${r.note||''}" placeholder="可留空">`}</div>`}
function setResult(id,result){draft.results[id].result=result; renderInspect()}
async function uploadPhoto(ev,itemId){const f=ev.target.files[0]; if(!f) return; const fd=new FormData(); fd.append('photo',f); const res=await fetch('/api/upload',{method:'POST',body:fd}).then(r=>r.json()); draft.results[itemId].photoUrls.push(res.url); renderInspect()}
async function submitInspection(){const results=Object.values(draft.results); const missing=results.filter(x=>!x.result); if(missing.length){alert(`尚有 ${missing.length} 項未判定`); return} const badMissing=results.filter(x=>x.result==='異常'&&(!x.abnormalDescription||!x.action)); if(badMissing.length){alert('異常項目必須填寫異常說明與處理方式');return} await api('/api/records',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({date:today(),time:new Date().toTimeString().slice(0,5),userId:profile.userId,displayName:profile.displayName,shift:draft.shift,weather:draft.weather,locationId:draft.locationId,location:draft.location,results})}); alert('已送出巡檢紀錄'); await loadRecords(); setRoute('home')}
function renderAbnormal(){const list=records.filter(r=>r.result==='異常'||r.result==='待注意'); app.innerHTML=header('異常追蹤','紅色為異常、橘色為待注意')+`<div class="wrap">${list.length?list.map(r=>`<div class="card"><h3 class="${r.result==='異常'?'dangerText':''}">${r.location}｜${r.item}</h3><span class="pill ${r.result==='異常'?'bad':'warn'}">${r.result}</span><span class="pill na">${r.status}</span><div class="small">${r.abnormalDescription||r.note||''}<br>處理：${r.action||'未填'}<br>期限：${r.dueDate||'未填'}<br>人員：${r.displayName||''}</div><div>${(r.photoUrls||[]).map(u=>`<img class="photo" src="${u}">`).join('')}</div></div>`).join(''):'<div class="card">目前沒有異常。</div>'}</div>`+nav()}
function renderAdmin(){const s=summary(); app.innerHTML=header('主管儀表板','複核、統計、匯出')+`<div class="wrap"><div class="grid"><div class="stat"><b>${s.ab.length}</b><span>異常/待注意</span></div><div class="stat"><b class="dangerText">${s.pending.length}</b><span>待處理</span></div></div><div class="card"><h3>資料匯出</h3><button class="btn dark" onclick="location.href='/api/export.csv'">下載 CSV</button></div><div class="card"><h3>待複核</h3>${s.pending.slice(0,50).map(r=>`<div class="item"><b>${r.location}｜${r.item}</b><div class="small">${r.abnormalDescription||''}</div><div class="row"><button class="btn" onclick="review('${r.id}','追蹤中')">追蹤中</button><button class="btn primary" onclick="review('${r.id}','已改善')">已改善</button></div></div>`).join('')||'<div class="small">無待複核項目</div>'}</div></div>`+nav()}
async function review(id,status){const note=prompt('主管複核說明', status)||status; await api(`/api/records/${id}/review`,{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify({status,supervisorStatus:status==='已改善'?'已複核':'追蹤中',supervisorNote:note,supervisorUser:profile.displayName})}); await loadRecords(); renderAdmin()}
init().catch(e=>{app.innerHTML=`<div class="wrap"><div class="card"><h3>系統啟動失敗</h3><div class="small">${e.message}</div></div></div>`})
